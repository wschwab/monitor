# Monitor Project Environment Variables - Template
# Copy to .env and fill in values

# Tempo Chain
TEMPO_RPC_URL=https://<username>:<password>@rpc.tempo.xyz
TEMPO_CHAIN_ID=4217

# Treasury Contract
# Deployed on Tempo mainnet (chain 4217) at: 0x95c9009c82FEd445dEDeecEfC2abA6edEb920941
# Verified: https://contracts.tempo.xyz/contracts/4217/0x95c9009c82fed445dedeecefc2aba6edeb920941
# Uses Permit2 (0x000000000022D473030F116dDEE9F6B43aC78BA3) for single-step USDC budget deposits
TREASURY_ADDRESS=0x95c9009c82FEd445dEDeecEfC2abA6edEb920941

# Backend Server
PORT=3001
WS_PORT=3002
NODE_ENV=development

# LLM Provider ('anthropic', 'openai', or 'mock')
LLM_PROVIDER=mock
LLM_API_KEY=

# MPP
MPP_BASE_URL=https://mpp.example.com
MPP_API_KEY=

# Premium Providers (optional)
CERN_API_KEY=
CIA_API_KEY=

# Demo Mode (set to 'true' to use fixture data)
DEMO_MODE=false
